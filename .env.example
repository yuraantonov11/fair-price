# Supabase configuration used by src/utils/supabaseClient.ts
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_LOG_LEVEL=info

# Optional explicit URL for crawler script. If empty, crawler falls back to VITE_SUPABASE_URL.
SUPABASE_URL=

# Required for scripts/crawl.mjs and GitHub Actions crawl workflow.
# Never commit real key values.
SUPABASE_SERVICE_ROLE_KEY=

# Optional crawler tuning (defaults are in scripts/crawl.mjs)
CRAWL_CONCURRENCY=20
CRAWL_DELAY_MS=2000
CRAWL_OFFSET=0
CRAWL_LIMIT=

# Optional override for Firefox Developer Edition binary used by wxt dev:firefox
# Example (Windows): C:/Program Files/Firefox Developer Edition/firefox.exe
WXT_FIREFOX_BINARY=

# Optional page that opens automatically in dev browser profile
WXT_START_URL=https://dnipro-m.ua/tovar/akumulyatorna-lancyugova-pila-dms-201bc/

